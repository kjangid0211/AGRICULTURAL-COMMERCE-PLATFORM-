{
  "name": "agri-commerce-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "install-all": "npm install && npm install --workspace=apps/frontend && npm install --workspace=apps/backend",
    "backend": "npm start --workspace=apps/backend",
    "frontend": "npm run dev --workspace=apps/frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "seed": "npm run seed --workspace=apps/backend"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
